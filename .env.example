# Database — PostgreSQL connection string
# Railway: copy from your Railway Postgres service
# Neon: copy from neon.tech dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email — Resend API key (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Session — change this to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# App URL — your public domain, used to build magic-link URLs in emails
# Example: https://kennion.com  or  https://your-app.railway.app
APP_URL=https://your-app.railway.app

# Port — defaults to 5000 if not set (most hosts set this automatically)
# PORT=5000
